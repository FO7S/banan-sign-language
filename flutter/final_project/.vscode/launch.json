{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "final_project",
            "request": "launch",
            "type": "dart",
            "args": ["-d", "${input:selectDevice}"]
        },
        {
            "name": "final_project (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "args": ["-d", "${input:selectDevice}"]
        },
        {
            "name": "final_project (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": ["-d", "${input:selectDevice}"]
        }
    ],
    "inputs": [
        {
            "id": "selectDevice",
            "type": "pickString",
            "description": "Which device do you want to run on?",
            "options": [
                "android",
                "ios",
                "web-server",
                "chrome"
            ],
            "default": "android"
        }
    ]
}